{
  "description": "Claude-Codex Review Bridge: automated code review via Codex CLI",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/codex-review-stop.sh\"",
            "timeout": 120,
            "statusMessage": "CRB: Codex reviewing diff..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/codex-review-file.sh\"",
            "timeout": 60,
            "statusMessage": "CRB: Codex reviewing file..."
          }
        ]
      }
    ]
  }
}
